    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const vtData = $input.item.json.data && $input.item.json.data.attributes && $input.item.json.data.attributes.stats ? $input.item.json.data.attributes.stats : {};\nconst malicious = vtData.malicious || 0;\nconst suspicious = vtData.suspicious || 0;\nconst harmless = vtData.harmless || 0;\n\nlet vtRiskScore = 0;\n\nif (malicious > 5) {\n  vtRiskScore = 60;\n} else if (malicious > 0) {\n  vtRiskScore = 40;\n}\n\nif (suspicious > 0) {\n  vtRiskScore += 20;\n}\n\nreturn {\n  vtMalicious: malicious,\n  vtSuspicious: suspicious,\n  vtHarmless: harmless,\n  vtRiskScore: vtRiskScore\n};"
      },
