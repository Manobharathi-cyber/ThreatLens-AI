      "id": "b7fe6419-b99d-45ca-881b-c558bbe7553c",
      "name": "Validate URL Format",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        464,
        368
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const inputUrl = $input.item.json.body.url;\nconst fullUrl = inputUrl.toLowerCase();\n\nconst protocolMatch = inputUrl.match(/^https?:\\/\\/(.+)/);\nconst withoutProtocol = protocolMatch ? protocolMatch[1] : inputUrl;\n\nconst pathStart = withoutProtocol.indexOf('/');\nconst hostname = pathStart > -1 ? withoutProtocol.substring(0, pathStart) : withoutProtocol;\n\nconst domainLength = hostname.length;\nconst subdomains = hostname.split('.').length - 2;\nconst hasAtSymbol = inputUrl.includes('@');\nconst ipPattern = /\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b/;\nconst hasIpAddress = ipPattern.test(hostname);\n\nconst suspiciousKeywords = ['login', 'verify', 'secure', 'update', 'account', 'bank', 'password', 'reset'];\nconst foundKeywords = suspiciousKeywords.filter(keyword => fullUrl.includes(keyword));\n\nreturn {\n  url: inputUrl,\n  hostname: hostname,\n  domainLength: domainLength,\n  subdomains: subdomains,\n  hasAtSymbol: hasAtSymbol,\n  hasIpAddress: hasIpAddress,\n  foundKeywords: foundKeywords\n};"
      },
      "id": "5be6712d-dd0f-4515-9c86-fdbaef7d5ec4",
      "name": "Extract URL Features",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        272
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $input.item.json;\nlet riskScore = 0;\nconst reasons = [];\n\nif (data.hasAtSymbol) {\n  riskScore += 10;\n  reasons.push(\"Contains @ symbol (+10)\");\n}\n\nif (data.hasIpAddress) {\n  riskScore += 20;\n  reasons.push(\"Contains IP address (+20)\");\n}\n\nif (data.subdomains > 3) {\n  riskScore += 15;\n  reasons.push(\"More than 3 subdomains (+15)\");\n}\n\nconst keywordScores = {\n  login: 10,\n  verify: 10,\n  update: 10,\n  secure: 5,\n  bank: 15,\n  account: 5,\n  password: 10,\n  reset: 10\n};\n\nif (data.foundKeywords && data.foundKeywords.length > 0) {\n  data.foundKeywords.forEach(keyword => {\n    const score = keywordScores[keyword] || 0;\n    if (score > 0) {\n      riskScore += score;\n      reasons.push(\"Contains \\\"\" + keyword + \"\\\" keyword (+\" + score + \")\");\n    }\n  });\n}\n\nif (data.vtRiskScore) {\n  riskScore += data.vtRiskScore;\n  if (data.vtMalicious > 0) {\n    reasons.push(\"VirusTotal: \" + data.vtMalicious + \" malicious detections\");\n  }\n  if (data.vtSuspicious > 0) {\n    reasons.push(\"VirusTotal: \" + data.vtSuspicious + \" suspicious detections\");\n  }\n}\n\nlet classification;\nif (riskScore <= 30) {\n  classification = \"Safe\";\n} else if (riskScore <= 70) {\n  classification = \"Suspicious\";\n} else {\n  classification = \"Malicious\";\n}\n\nreturn {\n  url: data.url,\n  hostname: data.hostname,\n  risk_score: riskScore,\n  classification: classification,\n  reasons: reasons,\n  virustotal: {\n    malicious: data.vtMalicious || 0,\n    suspicious: data.vtSuspicious || 0,\n    harmless: data.vtHarmless || 0\n  }\n};"
      },
